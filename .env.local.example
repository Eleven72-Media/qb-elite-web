# Copy to .env.local and fill in.

# Supabase — pull from qb_elite_source/.env (same project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL — used for OAuth + email-verify callback redirects
# Local: http://localhost:3000
# Vercel preview: leave empty, defaults to window.location.origin
# Production: https://app.quarterbackelite.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — added in Sprint 4
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
